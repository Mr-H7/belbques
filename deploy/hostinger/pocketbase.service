[Unit]
Description=PocketBase Service (Benha Survey)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/belbques/apps/pocketbase
EnvironmentFile=/etc/belbques/pocketbase.env
ExecStart=/var/www/belbques/apps/pocketbase/pocketbase serve --http=127.0.0.1:8090 --dir=/var/www/belbques/apps/pocketbase/pb_data --migrationsDir=/var/www/belbques/apps/pocketbase/pb_migrations --hooksDir=/var/www/belbques/apps/pocketbase/pb_hooks --hooksWatch=false --encryptionEnv=PB_ENCRYPTION_KEY
Restart=always
RestartSec=5
LimitNOFILE=65535
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
