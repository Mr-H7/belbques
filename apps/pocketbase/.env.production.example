# 32+ chars required by PocketBase encryptionEnv
PB_ENCRYPTION_KEY=CHANGE_ME_TO_A_RANDOM_32_PLUS_CHAR_SECRET

# Use strong credentials and rotate regularly.
PB_SUPERUSER_EMAIL=owner@yourdomain.com
PB_SUPERUSER_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Optional bootstrap admin_users account for web admin dashboard
PB_ADMIN_EMAIL=admin@yourdomain.com
PB_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
